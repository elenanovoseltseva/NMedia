<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:padding="@dimen/padding"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/avatar"
        android:layout_width="@dimen/size"
        android:layout_height="@dimen/size"
        android:contentDescription="@string/description_post_author_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        tools:src="@sample/posts_avatars" />

    <TextView
        android:id="@+id/author"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding"

        android:singleLine="true"

        app:layout_constraintBottom_toTopOf="@id/published"
        app:layout_constraintStart_toEndOf="@id/avatar"
        app:layout_constraintTop_toTopOf="@id/avatar"
        app:layout_constraintEnd_toStartOf="@id/menu"

        app:layout_constraintVertical_chainStyle="packed"
        tools:text="@sample/posts.json/data/author" />

    <TextView
        android:id="@+id/published"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_marginStart="@dimen/padding"

        app:layout_constraintBottom_toBottomOf="@id/avatar"
        app:layout_constraintStart_toEndOf="@id/avatar"
        app:layout_constraintTop_toBottomOf="@id/author"

        tools:text="@sample/posts.json/data/published" />

    <ImageButton
        android:id="@+id/menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:background="@android:color/transparent"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        tools:src="@drawable/baseline_more_vert_24"
        />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        app:constraint_referenced_ids="avatar, published, menu"
        app:barrierDirection="bottom"/>

    <TextView
        android:id="@+id/content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:autoLink="web"
        android:layout_marginTop="@dimen/padding"
        app:layout_constraintTop_toBottomOf="@id/barrier_header"

        app:layout_constraintBottom_toTopOf="@id/barrier_content"
        android:layout_marginBottom="@dimen/padding"

        tools:text="@sample/posts.json/data/content" />

    <!-- Barrier 2 -->

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        app:barrierDirection="bottom"
        app:constraint_referenced_ids="content" />

    <!-- Liked -->

    <ImageView
        android:id="@+id/likedImg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/icon_liked"

        android:layout_marginStart="@dimen/padding"

        android:layout_marginTop="@dimen/halfPadding"
        app:layout_constraintTop_toBottomOf="@id/barrier_content" />

    <TextView
        android:id="@+id/likedTxt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:text="1000"

        app:layout_constraintStart_toEndOf="@id/likedImg"
        android:layout_marginStart="@dimen/halfPadding"

        app:layout_constraintTop_toTopOf="@id/likedImg"
        app:layout_constraintBottom_toBottomOf="@id/likedImg"

        app:layout_constraintTop_toBottomOf="@id/barrier_content" />

    <!-- Shared -->

    <ImageView
        android:id="@+id/sharedImg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/icon_shared"

        app:layout_constraintTop_toTopOf="@id/likedImg"
        app:layout_constraintBottom_toBottomOf="@id/likedImg"

        app:layout_constraintStart_toEndOf="@id/likedTxt"
        android:layout_marginStart="@dimen/size" />

    <TextView
        android:id="@+id/sharedTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2000"

        app:layout_constraintStart_toEndOf="@id/sharedImg"
        android:layout_marginStart="@dimen/halfPadding"

        app:layout_constraintTop_toTopOf="@id/likedImg"
        app:layout_constraintBottom_toBottomOf="@id/likedImg" />


    <!-- Viewed -->

    <ImageView
        android:id="@+id/viewedImg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/icon_viewed"

        app:layout_constraintEnd_toStartOf="@id/viewedTxt"
        android:layout_marginEnd="@dimen/halfPadding"

        app:layout_constraintTop_toTopOf="@id/likedImg"
        app:layout_constraintBottom_toBottomOf="@id/likedImg" />

    <TextView
        android:id="@+id/viewedTxt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        app:layout_constraintEnd_toEndOf="parent"

        android:text="3000"

        app:layout_constraintTop_toTopOf="@id/likedImg"
        app:layout_constraintBottom_toBottomOf="@id/likedImg" />

</androidx.constraintlayout.widget.ConstraintLayout>
